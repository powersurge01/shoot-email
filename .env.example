DATABASE_URL=postgres://shoot_email:shoot_email@localhost:5432/shoot_email
TEST_DATABASE_URL=postgres://shoot_email:shoot_email@localhost:5432/shoot_email_test
INBOUND_DOMAIN=yoyowza.com
MAIL_PROVIDER=mock
SHOOT_EMAIL_ENV=development
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_FROM_EMAIL=
# Generate with: openssl rand -hex 32
INBOUND_WEBHOOK_TOKEN=replace-with-a-random-secret
# Temporary hackathon demo transport. Use OAuth 2.1 for production MCP access.
ENABLE_REMOTE_MCP_DEMO=false
REMOTE_MCP_DEMO_TOKEN=replace-with-a-separate-random-secret
REMOTE_MCP_DEMO_SUBJECT=hackathon-judge-demo-v1
REMOTE_MCP_DEMO_SESSION=hackathon-judge-session-v1
PORT=3000
CUSTOM_ALIAS_CHANGE_COOLDOWN_DAYS=30

# Outbound abuse controls
OUTBOUND_SENDING_ENABLED=true
OUTBOUND_GLOBAL_HOURLY_LIMIT=20
OUTBOUND_GLOBAL_DAILY_LIMIT=100
OUTBOUND_GUEST_HOURLY_LIMIT=3
OUTBOUND_GUEST_DAILY_LIMIT=10
OUTBOUND_GUEST_NEW_RECIPIENT_DAILY_LIMIT=2
OUTBOUND_GUEST_MIN_INTERVAL_SECONDS=15
OUTBOUND_GUEST_SESSION_HOURLY_LIMIT=3
OUTBOUND_REGISTERED_HOURLY_LIMIT=10
OUTBOUND_REGISTERED_DAILY_LIMIT=50
OUTBOUND_REGISTERED_NEW_RECIPIENT_DAILY_LIMIT=10
OUTBOUND_REGISTERED_MIN_INTERVAL_SECONDS=5
OUTBOUND_REGISTERED_SESSION_HOURLY_LIMIT=10
